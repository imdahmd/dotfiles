#!/bin/bash

function log {
    if [ -n "$LOGGING_ENABLED" ]; then
        echo "$1" >> ~/.emacslauncher.log
    fi
}

emacs="/opt/homebrew/bin/emacs"
emacsclient="/opt/homebrew/bin/emacsclient"

# Start the server silently if not already running, then wait for it to be ready
if ! $emacsclient --eval "t" >/dev/null 2>&1; then
    $emacs --daemon >/dev/null 2>&1
    for i in $(seq 1 20); do
        $emacsclient --eval "t" >/dev/null 2>&1 && break
        sleep 0.5
    done
fi

# Check if a GUI frame exists
NUM_OF_GUI_FRAMES=$($emacsclient --eval "(length (seq-filter (lambda (f) (eq (framep f) 'ns)) (frame-list)))" 2>/dev/null)

# Detect if called as a git editor (commit message, rebase todo, etc.)
is_git_editor=false
for arg in "$@"; do
    case "$(basename "$arg")" in
        COMMIT_EDITMSG|MERGE_MSG|git-rebase-todo|TAG_EDITMSG|SQUASH_MSG)
            is_git_editor=true
            break
            ;;
    esac
done

if $is_git_editor; then
    log "Git editor mode: opening $*"
    if [ "${NUM_OF_GUI_FRAMES:-0}" -eq 0 ] 2>/dev/null; then
        $emacsclient -c -- "$@"
    else
        $emacsclient -- "$@"
    fi
else
    if [ "${NUM_OF_GUI_FRAMES:-0}" -eq 0 ] 2>/dev/null; then
        log "Opening $* in new frame"
        $emacsclient -c -n -- "$@"
    else
        if [ "$#" -ne 0 ]; then
            log "Opening $* in existing frame"
            $emacsclient -n -- "$@"
        fi
    fi
    $emacsclient -e "(select-frame-set-input-focus (selected-frame))" >/dev/null 2>&1
fi
